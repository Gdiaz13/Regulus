<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Regulas.MauiApp.TcgPage"
             Title="TCG">
    <ScrollView>
        <VerticalStackLayout Padding="20"
                             Spacing="16"
                             MaximumWidthRequest="760"
                             HorizontalOptions="Center">
            <VerticalStackLayout Spacing="4">
                <Label Text="TCG cards"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource MidnightBlue}, Dark={StaticResource White}}" />
                <Label Text="Record Pokemon, Magic, and One Piece prices by hand. Type, condition, grade, currency, and game are stored so listings stay comparable."
                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
            </VerticalStackLayout>

            <Border Stroke="{AppThemeBinding Light={StaticResource RegulasLightBorder}, Dark={StaticResource RegulasDarkBorder}}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource RegulasLightSurface}, Dark={StaticResource RegulasDarkSurface}}"
                    StrokeShape="RoundRectangle 8"
                    Padding="14">
                <VerticalStackLayout Spacing="12">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Browse Pokemon, Magic, and One Piece"
                               FontSize="20"
                               FontAttributes="Bold" />
                        <Label Text="Search provider data through Regulas.Api, then open details to capture market price when available."
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                    </VerticalStackLayout>
                    <Grid ColumnDefinitions="*,Auto"
                          RowDefinitions="Auto,Auto"
                          ColumnSpacing="10">
                        <Picker Grid.ColumnSpan="2"
                                ItemsSource="{Binding BrowseGames}"
                                SelectedItem="{Binding BrowseGame}" />
                        <Entry Grid.Row="1"
                               Text="{Binding BrowseQuery}"
                               Placeholder="Card name" />
                        <Button Grid.Row="1"
                                Grid.Column="1"
                                Text="Search"
                                Command="{Binding SearchCardsCommand}"
                                IsEnabled="{Binding CanSearchCards}" />
                    </Grid>
                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}" />
                    <Label Text="{Binding BrowseMessageText}"
                           IsVisible="{Binding ShowBrowseMessage}"
                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                    <CollectionView ItemsSource="{Binding ProviderCards}"
                                    SelectionMode="None"
                                    IsVisible="{Binding HasProviderCards}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Stroke="{AppThemeBinding Light={StaticResource RegulasLightBorder}, Dark={StaticResource RegulasDarkBorder}}"
                                        StrokeShape="RoundRectangle 8"
                                        Padding="10"
                                        Margin="0,0,0,8">
                                    <Grid ColumnDefinitions="64,*"
                                          RowDefinitions="Auto,Auto,Auto"
                                          ColumnSpacing="10">
                                        <Image Grid.RowSpan="3"
                                               Source="{Binding ImageUrl}"
                                               HeightRequest="52"
                                               WidthRequest="52"
                                               Aspect="AspectFit" />
                                        <Label Grid.Column="1"
                                               Text="{Binding Name}"
                                               FontAttributes="Bold" />
                                        <Label Grid.Row="1"
                                               Grid.Column="1"
                                               Text="{Binding Details}"
                                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                                        <HorizontalStackLayout Grid.Row="2"
                                                               Grid.Column="1"
                                                               Spacing="10">
                                            <Label Text="{Binding Price}"
                                                   VerticalOptions="Center"
                                                   FontAttributes="Bold" />
                                            <Button Text="Open"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenCardCommand}"
                                                    CommandParameter="{Binding .}" />
                                        </HorizontalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <Border IsVisible="{Binding HasProviderDetail}"
                            Stroke="{AppThemeBinding Light={StaticResource RegulasLightBorder}, Dark={StaticResource RegulasDarkBorder}}"
                            StrokeShape="RoundRectangle 8"
                            Padding="10">
                        <VerticalStackLayout Spacing="8">
                            <Image Source="{Binding BrowseDetailImageUrl}"
                                   HeightRequest="240"
                                   Aspect="AspectFit" />
                            <Label Text="{Binding BrowseDetailName}"
                                   FontSize="18"
                                   FontAttributes="Bold" />
                            <Label Text="{Binding BrowseDetailText}"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                            <CollectionView ItemsSource="{Binding ProviderPrices}"
                                            SelectionMode="None">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Text="{Binding Label}" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding Price}"
                                                   FontAttributes="Bold" />
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Button Text="Sign in"
                    Command="{Binding OpenAccountCommand}"
                    IsVisible="{Binding IsAnonymous}" />

            <Border IsVisible="{Binding IsAuthenticated}"
                    Stroke="{AppThemeBinding Light={StaticResource RegulasLightBorder}, Dark={StaticResource RegulasDarkBorder}}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource RegulasLightSurface}, Dark={StaticResource RegulasDarkSurface}}"
                    StrokeShape="RoundRectangle 8"
                    Padding="14">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,*"
                          RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                          ColumnSpacing="10"
                          RowSpacing="10">
                        <Entry Text="{Binding Symbol}"
                               Placeholder="Card code e.g. SV3-125"
                               MaxLength="32" />
                        <Entry Grid.Column="1"
                               Text="{Binding Name}"
                               Placeholder="Card name optional" />
                        <Picker Grid.Row="1"
                                ItemsSource="{Binding TcgGames}"
                                SelectedItem="{Binding Category}" />
                        <Entry Grid.Row="1"
                               Grid.Column="1"
                               Text="{Binding Date}"
                               Placeholder="Date yyyy-mm-dd" />
                        <Entry Grid.Row="2"
                               Text="{Binding Price}"
                               Keyboard="Numeric"
                               Placeholder="Price e.g. 120.50" />
                        <Picker Grid.Row="2"
                                Grid.Column="1"
                                ItemsSource="{Binding PriceTypes}"
                                SelectedItem="{Binding PriceType}" />
                        <Entry Grid.Row="3"
                               Text="{Binding Condition}"
                               Placeholder="Condition e.g. Near Mint" />
                        <Entry Grid.Row="3"
                               Grid.Column="1"
                               Text="{Binding Grade}"
                               Placeholder="Grade e.g. PSA 9" />
                        <Entry Grid.Row="4"
                               Text="{Binding Currency}"
                               MaxLength="8"
                               Placeholder="Currency" />
                    </Grid>
                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="10">
                        <Button Text="Save price"
                                Command="{Binding SaveCommand}"
                                IsEnabled="{Binding CanSave}" />
                        <Button Grid.Column="1"
                                Text="Load stored"
                                Command="{Binding LoadCommand}"
                                IsEnabled="{Binding CanLoad}" />
                    </Grid>
                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}" />
                    <Label Text="{Binding MessageText}"
                           IsVisible="{Binding ShowMessage}"
                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                </VerticalStackLayout>
            </Border>

            <CollectionView ItemsSource="{Binding Points}"
                            SelectionMode="None"
                            IsVisible="{Binding HasPoints}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Stroke="{AppThemeBinding Light={StaticResource RegulasLightBorder}, Dark={StaticResource RegulasDarkBorder}}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource RegulasLightSurface}, Dark={StaticResource RegulasDarkSurface}}"
                                StrokeShape="RoundRectangle 8"
                                Padding="14"
                                Margin="0,0,0,10">
                            <Grid ColumnDefinitions="*,Auto"
                                  RowDefinitions="Auto,Auto"
                                  ColumnSpacing="12">
                                <Label Text="{Binding Date}"
                                       FontAttributes="Bold" />
                                <Label Grid.Column="1"
                                       Text="{Binding Price}"
                                       FontAttributes="Bold" />
                                <Label Grid.Row="1"
                                       Text="{Binding Meta}"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                                <Label Grid.Row="1"
                                       Grid.Column="1"
                                       Text="{Binding Source}"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
