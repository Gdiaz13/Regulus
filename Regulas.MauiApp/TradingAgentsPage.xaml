<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Regulas.MauiApp.TradingAgentsPage"
             Title="Research">
    <ScrollView>
        <VerticalStackLayout Padding="20"
                             Spacing="16"
                             MaximumWidthRequest="900"
                             HorizontalOptions="Center">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
                <VerticalStackLayout Spacing="4">
                    <Label Text="TradingAgents"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource MidnightBlue}, Dark={StaticResource White}}" />
                    <Label Text="Run the separate stock research branch through Regulas.Api."
                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                </VerticalStackLayout>
                <ActivityIndicator Grid.Column="1"
                                   IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}" />
            </Grid>

            <Border Stroke="{AppThemeBinding Light={StaticResource RegulasLightBorder}, Dark={StaticResource RegulasDarkBorder}}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource RegulasLightSurface}, Dark={StaticResource RegulasDarkSurface}}"
                    StrokeShape="RoundRectangle 8"
                    Padding="14">
                <VerticalStackLayout Spacing="8">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="10">
                        <Label Text="{Binding StatusText}"
                               FontAttributes="Bold" />
                        <Button Grid.Column="1"
                                Text="Refresh"
                                Command="{Binding RefreshStatusCommand}" />
                    </Grid>
                    <Label Text="{Binding ModelStatusText}"
                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                    <Label Text="{Binding PurposeText}"
                           LineBreakMode="WordWrap"
                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                    <Label Text="MOCK"
                           IsVisible="{Binding IsModelMock}"
                           FontAttributes="Bold"
                           TextColor="{StaticResource RegulasDanger}" />
                    <ActivityIndicator IsRunning="{Binding IsStatusBusy}"
                                       IsVisible="{Binding IsStatusBusy}" />
                </VerticalStackLayout>
            </Border>

            <Border Stroke="{AppThemeBinding Light={StaticResource RegulasLightBorder}, Dark={StaticResource RegulasDarkBorder}}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource RegulasLightSurface}, Dark={StaticResource RegulasDarkSurface}}"
                    StrokeShape="RoundRectangle 8"
                    Padding="14">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,*"
                          RowDefinitions="Auto,Auto"
                          ColumnSpacing="10"
                          RowSpacing="10">
                        <Entry Text="{Binding Symbol}"
                               Placeholder="Symbol"
                               MaxLength="32" />
                        <Entry Grid.Column="1"
                               Text="{Binding CompanyName}"
                               Placeholder="Company optional" />
                        <Entry Grid.Row="1"
                               Text="{Binding CurrentPrice}"
                               Keyboard="Numeric"
                               Placeholder="Current price" />
                        <Entry Grid.Row="1"
                               Grid.Column="1"
                               Text="{Binding AnalysisDate}"
                               Placeholder="yyyy-mm-dd optional" />
                    </Grid>
                    <Button Text="Analyze stock"
                            Command="{Binding AnalyzeCommand}"
                            IsEnabled="{Binding CanAnalyze}" />
                    <Label Text="{Binding MessageText}"
                           IsVisible="{Binding ShowMessage}"
                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                </VerticalStackLayout>
            </Border>

            <Border IsVisible="{Binding HasResult}"
                    Stroke="{AppThemeBinding Light={StaticResource RegulasLightBorder}, Dark={StaticResource RegulasDarkBorder}}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource RegulasLightSurface}, Dark={StaticResource RegulasDarkSurface}}"
                    StrokeShape="RoundRectangle 8"
                    Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="10">
                        <VerticalStackLayout Spacing="3">
                            <Label Text="{Binding RecommendationText}"
                                   FontSize="20"
                                   FontAttributes="Bold" />
                            <Label Text="{Binding ModelText}"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                        </VerticalStackLayout>
                        <Label Grid.Column="1"
                               Text="MOCK"
                               IsVisible="{Binding IsResultMock}"
                               FontAttributes="Bold"
                               TextColor="{StaticResource RegulasDanger}" />
                    </Grid>
                    <Label Text="{Binding ResultDateText}"
                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                    <Label Text="{Binding SummaryText}"
                           LineBreakMode="WordWrap" />
                    <Label Text="{Binding ScoreText}"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Primary}" />
                </VerticalStackLayout>
            </Border>

            <CollectionView ItemsSource="{Binding BullishArguments}"
                            SelectionMode="None"
                            IsVisible="{Binding HasBullish}">
                <CollectionView.Header>
                    <Label Text="Bullish arguments"
                           FontSize="18"
                           FontAttributes="Bold" />
                </CollectionView.Header>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Stroke="{AppThemeBinding Light={StaticResource RegulasLightBorder}, Dark={StaticResource RegulasDarkBorder}}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource RegulasLightSurface}, Dark={StaticResource RegulasDarkSurface}}"
                                StrokeShape="RoundRectangle 8"
                                Padding="12"
                                Margin="0,0,0,8">
                            <Label Text="{Binding Text}"
                                   LineBreakMode="WordWrap" />
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <CollectionView ItemsSource="{Binding BearishArguments}"
                            SelectionMode="None"
                            IsVisible="{Binding HasBearish}">
                <CollectionView.Header>
                    <Label Text="Bearish arguments"
                           FontSize="18"
                           FontAttributes="Bold" />
                </CollectionView.Header>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Stroke="{AppThemeBinding Light={StaticResource RegulasLightBorder}, Dark={StaticResource RegulasDarkBorder}}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource RegulasLightSurface}, Dark={StaticResource RegulasDarkSurface}}"
                                StrokeShape="RoundRectangle 8"
                                Padding="12"
                                Margin="0,0,0,8">
                            <Label Text="{Binding Text}"
                                   LineBreakMode="WordWrap" />
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <CollectionView ItemsSource="{Binding Warnings}"
                            SelectionMode="None"
                            IsVisible="{Binding HasWarnings}">
                <CollectionView.Header>
                    <Label Text="Warnings"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource RegulasDanger}" />
                </CollectionView.Header>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Stroke="{StaticResource RegulasDanger}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource RegulasLightSurface}, Dark={StaticResource RegulasDarkSurface}}"
                                StrokeShape="RoundRectangle 8"
                                Padding="12"
                                Margin="0,0,0,8">
                            <Label Text="{Binding Text}"
                                   LineBreakMode="WordWrap"
                                   TextColor="{StaticResource RegulasDanger}" />
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Border IsVisible="{Binding HasRawDecision}"
                    Stroke="{AppThemeBinding Light={StaticResource RegulasLightBorder}, Dark={StaticResource RegulasDarkBorder}}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource RegulasLightSurface}, Dark={StaticResource RegulasDarkSurface}}"
                    StrokeShape="RoundRectangle 8"
                    Padding="14">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Raw decision"
                           FontAttributes="Bold" />
                    <Label Text="{Binding RawDecisionText}"
                           FontFamily="monospace"
                           LineBreakMode="WordWrap"
                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
