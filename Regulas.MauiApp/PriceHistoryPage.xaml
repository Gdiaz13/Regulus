<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Regulas.MauiApp.PriceHistoryPage"
             Title="Price History">
    <ScrollView>
        <VerticalStackLayout Padding="20"
                             Spacing="16"
                             MaximumWidthRequest="840"
                             HorizontalOptions="Center">
            <VerticalStackLayout Spacing="4">
                <Label Text="Price history"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource MidnightBlue}, Dark={StaticResource White}}" />
                <Label Text="Capture provider prices and read the stored history from Regulas.Api."
                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
            </VerticalStackLayout>

            <Border Stroke="{AppThemeBinding Light={StaticResource RegulasLightBorder}, Dark={StaticResource RegulasDarkBorder}}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource RegulasLightSurface}, Dark={StaticResource RegulasDarkSurface}}"
                    StrokeShape="RoundRectangle 8"
                    Padding="14">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="10">
                        <Entry Text="{Binding Symbol}"
                               Placeholder="Symbol"
                               ReturnType="Done" />
                        <ActivityIndicator Grid.Column="1"
                                           IsRunning="{Binding IsBusy}"
                                           IsVisible="{Binding IsBusy}" />
                    </Grid>
                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="10">
                        <Picker ItemsSource="{Binding AssetTypes}"
                                SelectedItem="{Binding AssetType}" />
                        <Picker Grid.Column="1"
                                ItemsSource="{Binding TakeOptions}"
                                SelectedItem="{Binding Take}" />
                    </Grid>
                    <HorizontalStackLayout Spacing="10">
                        <Button Text="Load stored"
                                Command="{Binding LoadCommand}"
                                IsEnabled="{Binding CanRun}" />
                        <Button Text="Capture"
                                Command="{Binding CaptureCommand}"
                                IsEnabled="{Binding CanRun}" />
                    </HorizontalStackLayout>
                    <Label Text="{Binding MessageText}"
                           IsVisible="{Binding ShowMessage}"
                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout IsVisible="{Binding HasHistory}"
                                 Spacing="16">
                <Border Stroke="{AppThemeBinding Light={StaticResource RegulasLightBorder}, Dark={StaticResource RegulasDarkBorder}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource RegulasLightSurface}, Dark={StaticResource RegulasDarkSurface}}"
                        StrokeShape="RoundRectangle 8"
                        Padding="16">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="{Binding SummaryText}"
                               FontAttributes="Bold" />
                        <Label Text="{Binding LatestCloseText}"
                               FontSize="20"
                               FontAttributes="Bold" />
                        <Label Text="{Binding SourceText}"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                    </VerticalStackLayout>
                </Border>

                <CollectionView ItemsSource="{Binding Points}"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Stroke="{AppThemeBinding Light={StaticResource RegulasLightBorder}, Dark={StaticResource RegulasDarkBorder}}"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource RegulasLightSurface}, Dark={StaticResource RegulasDarkSurface}}"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="14"
                                    Margin="0,0,0,10">
                                <Grid ColumnDefinitions="*,Auto"
                                      RowDefinitions="Auto,Auto,Auto"
                                      ColumnSpacing="12">
                                    <Label Text="{Binding Date}"
                                           FontAttributes="Bold" />
                                    <Label Grid.Column="1"
                                           Text="{Binding Close}"
                                           FontAttributes="Bold" />
                                    <Label Grid.Row="1"
                                           Text="{Binding Range}"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                                    <Label Grid.Row="1"
                                           Grid.Column="1"
                                           Text="{Binding Source}"
                                           TextColor="{StaticResource Primary}" />
                                    <Label Grid.Row="2"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding Volume}"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
