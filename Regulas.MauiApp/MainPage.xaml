<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Regulas.MauiApp.MainPage"
             x:Name="HomeRoot"
             Title="Regulas">
    <RefreshView IsRefreshing="{Binding IsBusy, Mode=OneWay}"
                 Command="{Binding RefreshCommand}">
        <ScrollView>
            <VerticalStackLayout Padding="20"
                                 Spacing="16"
                                 MaximumWidthRequest="980"
                                 HorizontalOptions="Center">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Regulas"
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource MidnightBlue}, Dark={StaticResource White}}" />
                        <Label Text="Portfolio and research gateway"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                    </VerticalStackLayout>
                    <Button Grid.Column="1"
                            Text="Refresh"
                            Command="{Binding RefreshCommand}"
                            IsEnabled="{Binding CanRefresh}" />
                </Grid>

                <Border Stroke="{AppThemeBinding Light={StaticResource RegulasLightBorder}, Dark={StaticResource RegulasDarkBorder}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource RegulasLightSurface}, Dark={StaticResource RegulasDarkSurface}}"
                        StrokeShape="RoundRectangle 8"
                        Padding="16">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="{Binding AccountText}"
                               FontAttributes="Bold" />
                        <Button Text="Sign in"
                                Command="{Binding OpenAccountCommand}"
                                IsVisible="{Binding IsAnonymous}" />
                        <BoxView HeightRequest="1"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource RegulasLightBorder}, Dark={StaticResource RegulasDarkBorder}}" />
                        <Label Text="{Binding StatusText}"
                               FontAttributes="Bold" />
                        <Label Text="{Binding DatabaseText}" />
                        <Label Text="{Binding MarketDataText}" />
                        <ActivityIndicator IsRunning="{Binding IsBusy}"
                                           IsVisible="{Binding IsBusy}" />
                    </VerticalStackLayout>
                </Border>

                <Border IsVisible="{Binding HasError}"
                        Stroke="{StaticResource RegulasDanger}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource RegulasLightSurface}, Dark={StaticResource RegulasDarkSurface}}"
                        StrokeShape="RoundRectangle 8"
                        Padding="14">
                    <Label Text="{Binding ErrorText}"
                           TextColor="{StaticResource RegulasDanger}" />
                </Border>

                <Label Text="Portfolio"
                       FontSize="20"
                       FontAttributes="Bold"
                       IsVisible="{Binding IsAuthenticated}" />

                <CollectionView ItemsSource="{Binding Stocks}"
                                SelectionMode="None"
                                IsVisible="{Binding IsAuthenticated}">
                    <CollectionView.EmptyView>
                        <Label Text="No saved stocks yet."
                               HorizontalTextAlignment="Center"
                               Padding="20"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Stroke="{AppThemeBinding Light={StaticResource RegulasLightBorder}, Dark={StaticResource RegulasDarkBorder}}"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource RegulasLightSurface}, Dark={StaticResource RegulasDarkSurface}}"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="14"
                                    Margin="0,0,0,10">
                                <Grid ColumnDefinitions="*,Auto"
                                      RowDefinitions="Auto,Auto,Auto"
                                      ColumnSpacing="12">
                                    <Label Text="{Binding Symbol}"
                                           FontAttributes="Bold"
                                           FontSize="18" />
                                    <Label Grid.Column="1"
                                           Text="{Binding PurchasePrice, StringFormat='${0:N2}'}"
                                           FontAttributes="Bold" />
                                    <Label Grid.Row="1"
                                           Text="{Binding CompanyName}"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                                    <Label Grid.Row="1"
                                           Grid.Column="1"
                                           Text="{Binding Industry}"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                                    <Button Grid.Row="2"
                                            Grid.ColumnSpan="2"
                                            Text="Details"
                                            HorizontalOptions="End"
                                            Command="{Binding Source={x:Reference HomeRoot}, Path=BindingContext.OpenStockCommand}"
                                            CommandParameter="{Binding .}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
